{
  "manifest_version": 3,
  "name": "Lanterne",
  "version": "0.1.0",
  "description": "Dit varme, personlige udgangspunkt. En ny fane der føles som hjem.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["https://api.open-meteo.com/*"],
  "icons": {
    "16": "icons/lanterne-16.png",
    "48": "icons/lanterne-48.png",
    "128": "icons/lanterne-128.png"
  }
}
