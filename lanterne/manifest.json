{
  "manifest_version": 3,
  "name": "Lanterne",
  "version": "0.7.0",
  "description": "Dit varme, personlige udgangspunkt. En ny fane der f\u00f8les som hjem.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "Lanterne \u2014 Scrapbook",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/lanterne-16.png",
      "48": "icons/lanterne-48.png",
      "128": "icons/lanterne-128.png"
    }
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "permissions": ["storage", "activeTab", "tabs", "cookies"],
  "host_permissions": ["https://api.open-meteo.com/*", "https://www.lectio.dk/*"],
  "web_accessible_resources": [{
    "resources": ["sounds/*"],
    "matches": ["<all_urls>"]
  }],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://www.youtube.com https://www.youtube-nocookie.com"
  },
  "icons": {
    "16": "icons/lanterne-16.png",
    "48": "icons/lanterne-48.png",
    "128": "icons/lanterne-128.png"
  }
}
